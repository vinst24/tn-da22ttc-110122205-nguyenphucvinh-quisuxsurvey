NODE_ENV=development
PORT=4000

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/KLTN_QUIS?schema=public"

# Frontend origin(s) for CORS. Use comma-separated values for Vercel/custom domains.
CORS_ORIGIN=http://localhost:5173

# JWT secrets (min 32 chars)
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars

# Local dev can stay false. Production HTTPS cookies are forced secure by NODE_ENV=production.
COOKIE_SECURE=false

# Optional: seed an initial admin user (used by `npm -w server run prisma:seed`)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe_12345678
ADMIN_FULL_NAME=System Admin